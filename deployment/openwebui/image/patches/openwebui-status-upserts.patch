+<script>
+	import AuditDetailPanel from './AuditDetailPanel.svelte';
+
+	export let item = {};
+	export let rawStatus = {};
+	export let last = false;
+	let expanded = false;
+	let userControlled = false;
+	let activeItemId = '';
+
+	const titleCase = (value) => {
+		const text = String(value ?? '').replaceAll('_', ' ').trim();
+		return text ? text.charAt(0).toUpperCase() + text.slice(1) : '';
+	};
+
+	const hasDetails = (item) =>
+		(item?.tasks?.length ?? 0) > 0 ||
+		(item?.members?.length ?? 0) > 0 ||
+		item?.input !== undefined ||
+		item?.output !== undefined ||
+		item?.error !== undefined ||
+		(item?.notices?.length ?? 0) > 0 ||
+		(item?.redacted_fields?.length ?? 0) > 0;
+
+	const rowId = (item) => item?.item_id || item?.group_id || item?.title || '';
+
+	const defaultExpanded = (item) =>
+		item?.status === 'running' && hasDetails(item) && item?.kind !== 'tool';
+
+	const handleToggle = () => {
+		userControlled = true;
+	};
+
+	const formatDuration = (value) => {
+		if (typeof value !== 'number' || !Number.isFinite(value)) return '';
+		if (value < 1000) return `${Math.max(0, Math.floor(value))}ms`;
+		return `${(value / 1000).toFixed(value < 10000 ? 1 : 0)}s`;
+	};
+
+	const statusLabel = (value) => {
+		const status = String(value ?? '').toLowerCase();
+		if (status === 'completed' || status === 'complete') return 'Completed';
+		if (status === 'error' || status === 'failed') return 'Failed';
+		if (status === 'queued') return 'Queued';
+		if (status === 'waiting') return 'Waiting';
+		return 'Running';
+	};
+
+	const tone = (item) => {
+		const status = String(item?.status ?? '').toLowerCase();
+		if (status === 'error' || status === 'failed') return 'rose';
+		if (status === 'completed' || status === 'complete') return 'emerald';
+		if (item?.kind === 'verify' || item?.kind === 'revise') return 'amber';
+		if (item?.kind === 'tool') return 'sky';
+		if (item?.kind === 'parallel') return 'indigo';
+		return 'slate';
+	};
+
+	const dotClasses = (item) => {
+		const t = tone(item);
+		if (t === 'rose') return 'bg-rose-400 ring-rose-400/20';
+		if (t === 'emerald') return 'bg-emerald-400 ring-emerald-400/20';
+		if (t === 'amber') return 'bg-amber-400 ring-amber-400/20';
+		if (t === 'sky') return 'bg-sky-400 ring-sky-400/20';
+		if (t === 'indigo') return 'bg-indigo-400 ring-indigo-400/20';
+		return 'bg-slate-400 ring-slate-400/20';
+	};
+
+	const badgeClasses = (item) => {
+		const t = tone(item);
+		if (t === 'rose') return 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-300/60 dark:bg-rose-950/20 dark:text-rose-200';
+		if (t === 'emerald') return 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-300/50 dark:bg-emerald-950/20 dark:text-emerald-200';
+		if (t === 'amber') return 'border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-300/50 dark:bg-amber-950/20 dark:text-amber-200';
+		if (t === 'sky') return 'border-sky-200 bg-sky-50 text-sky-700 dark:border-sky-300/50 dark:bg-sky-950/20 dark:text-sky-200';
+		if (t === 'indigo') return 'border-indigo-200 bg-indigo-50 text-indigo-700 dark:border-indigo-300/50 dark:bg-indigo-950/20 dark:text-indigo-200';
+		return 'border-slate-300 bg-slate-50 text-slate-600 dark:border-slate-400/40 dark:bg-slate-900/30 dark:text-slate-200';
+	};
+
+	$: {
+		const nextItemId = rowId(item);
+		if (nextItemId !== activeItemId) {
+			activeItemId = nextItemId;
+			userControlled = false;
+			expanded = defaultExpanded(item);
+		}
+	}
+</script>
+
+<div class="relative flex w-full gap-2 pl-1">
+	<div class="relative flex w-4 shrink-0 justify-center">
+		<span class="mt-2 h-2 w-2 rounded-full ring-4 {dotClasses(item)}"></span>
+		{#if !last}
+			<span class="absolute top-5 h-[calc(100%-0.25rem)] w-px bg-slate-200 dark:bg-slate-700/60"></span>
+		{/if}
