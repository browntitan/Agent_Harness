+
+		const totalElapsedMs =
+			numericTiming(timing?.total_elapsed_ms) ?? numericTiming(status?.elapsed_ms) ?? 0;
+		const statusElapsedMs = numericTiming(timing?.status_elapsed_ms);
+		const phaseElapsedMs =
+			numericTiming(timing?.phase_elapsed_ms) ?? numericTiming(status?.phase_elapsed_ms);
+		const terminal = timing?.kind === 'total' || isTerminalPhase(status) || status?.done === true;
+		const elapsedMs = terminal
+			? totalElapsedMs
+			: (numericTiming(timing?.elapsed_ms) ??
+				statusElapsedMs ??
+				phaseElapsedMs ??
+				totalElapsedMs);
+
+		return {
+			kind: terminal ? 'total' : 'stage',
+			live: Boolean(timing?.live) && !terminal && !done && status?.done !== true,
+			elapsed_ms: elapsedMs,
+			status_elapsed_ms: statusElapsedMs ?? elapsedMs,
+			phase_elapsed_ms: phaseElapsedMs ?? totalElapsedMs,
+			total_elapsed_ms: totalElapsedMs,
+			snapshot_timestamp_ms:
+				numericTiming(timing?.snapshot_timestamp_ms) ?? numericTiming(status?.timestamp) ?? 0
+		};
+	};
+
+	const resolvedAgenticTiming = (timing, nowMs) => {
+		if (!timing) {
+			return null;
+		}
+
+		let displayElapsedMs = timing.elapsed_ms;
+		if (timing.live && timing.snapshot_timestamp_ms > 0) {
+			displayElapsedMs += Math.max(0, nowMs - timing.snapshot_timestamp_ms);
+		}
+
+		return {
+			...timing,
+			displayElapsedMs,
+			label:
+				timing.kind === 'total'
+					? `Total ${formatElapsedMs(displayElapsedMs)}`
+					: formatElapsedMs(displayElapsedMs)
+		};
+	};
+
+	$: timerBase = status?.agentic_status?.version ? baseAgenticTiming(status, done) : null;
+	$: shouldTick = Boolean(timerBase?.live);
+	$: timer = resolvedAgenticTiming(timerBase, liveNowMs);
+	$: if (typeof window !== 'undefined' && shouldTick && timerHandle === null) {
+		liveNowMs = Date.now();
+		timerHandle = window.setInterval(() => {
+			liveNowMs = Date.now();
+		}, 1000);
+	} else if ((!shouldTick || typeof window === 'undefined') && timerHandle !== null) {
+		clearInterval(timerHandle);
+		timerHandle = null;
+	}
+
+	onDestroy(() => {
+		if (timerHandle !== null) {
+			clearInterval(timerHandle);
+		}
+	});
 </script>
 
