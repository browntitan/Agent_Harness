+<script>
+	import ActivityRow from './ActivityRow.svelte';
+
+	export let auditStatuses = [];
+	let rows = [];
+
+	const clean = (value) => String(value ?? '').trim();
+	const statusOf = (status) => status?.agentic_audit_item ?? legacyItem(status);
+	const keyOf = (row, index) => row?.item?.item_id ?? row?.status?.status_id ?? `audit-${index}`;
+	const isVisible = (item) => item && item.visible !== false;
+
+	const legacyItem = (status) => {
+		if (status?.agentic_tool_call?.version === 1) {
+			const tool = status.agentic_tool_call;
+			return {
+				version: 1,
+				item_id: status?.status_id ?? tool?.tool_call_id,
+				kind: 'tool',
+				status: tool?.status ?? status?.status,
+				title: `${tool?.tool_name ?? 'tool'} ${tool?.status === 'running' ? 'running' : tool?.status === 'error' ? 'failed' : 'ran'}`,
+				subtitle: tool?.output_preview || tool?.error_preview || tool?.error || tool?.input_preview || '',
+				actor: tool?.parent_agent || tool?.agent_name || '',
+				target: tool?.tool_name ?? '',
+				group_id: tool?.parallel_group_id ?? '',
+				chips: [tool?.agent_name, tool?.tool_name, tool?.duration_ms ? `${tool.duration_ms}ms` : ''].filter(Boolean),
+				started_at: tool?.started_at ?? '',
+				completed_at: tool?.completed_at ?? '',
+				duration_ms: tool?.duration_ms,
+				input: tool?.input,
+				output: tool?.output,
+				error: tool?.error,
+				notices: [
+					tool?.truncated ? `Payload limited to ${tool?.payload_limit_chars || 'the configured'} characters.` : '',
+					tool?.redacted_fields?.length ? 'Sensitive fields were redacted.' : ''
+				].filter(Boolean),
+				redacted_fields: tool?.redacted_fields ?? [],
+				payload_limit_chars: tool?.payload_limit_chars
+			};
+		}
+		if (status?.agentic_parallel_group?.version === 1) {
+			const group = status.agentic_parallel_group;
+			const isSoloToolWave = group?.group_kind === 'tool_wave' && Number(group?.size ?? 0) <= 1;
+			const isParallel = group?.execution_mode === 'parallel' && Number(group?.size ?? 0) > 1;
+			return {
+				version: 1,
+				item_id: status?.status_id ?? group?.group_id,
+				kind: isParallel ? 'parallel' : 'sequence',
+				status: group?.status ?? status?.status,
+				title: isParallel
+					? `Ran ${group?.size ?? group?.members?.length ?? 0} items in parallel`
+					: 'Sequenced work',
+				subtitle: group?.reason ?? '',
+				actor: status?.agent ?? '',
+				target: group?.group_kind === 'tool_wave' ? 'tools' : 'worker agents',
+				group_id: group?.group_id ?? '',
+				chips: [group?.execution_mode, String(group?.group_kind ?? '').replaceAll('_', ' ')].filter(Boolean),
+				members: group?.members ?? [],
+				duration_ms: group?.duration_ms,
+				visible: !isSoloToolWave
+			};
+		}
+		if (status?.agentic_agent_activity?.version === 1) {
+			const agent = status.agentic_agent_activity;
+			return {
+				version: 1,
+				item_id: status?.status_id ?? agent?.activity_id,
+				kind: agent?.role === 'planner' ? 'plan' : agent?.role === 'verifier' ? 'verify' : agent?.role === 'worker' ? 'handoff' : 'agent',
+				status: agent?.status ?? status?.status,
+				title: agent?.title ?? status?.label ?? '',
+				subtitle: agent?.description ?? status?.detail ?? '',
+				actor: agent?.parent_agent ?? '',
+				target: agent?.agent_name ?? '',
+				group_id: agent?.parallel_group_id ?? '',
+				chips: [agent?.role, agent?.task_id ? `task ${agent.task_id}` : '', agent?.job_id ? `job ${agent.job_id}` : ''].filter(Boolean),
+				started_at: agent?.started_at ?? '',
+				completed_at: agent?.completed_at ?? '',
+				duration_ms: agent?.duration_ms
+			};
+		}
+		return null;
+	};
+
+	$: rows = (auditStatuses ?? [])
+		.map((status, index) => ({ status, item: statusOf(status), index }))
+		.filter((row) => isVisible(row.item) && clean(row.item?.title));
+</script>
+
+{#if rows.length > 0}
+	<div class="mt-2 flex w-full flex-col gap-1.5">
+		{#each rows as row, idx (keyOf(row, idx))}
+			<ActivityRow item={row.item} rawStatus={row.status} last={idx === rows.length - 1} />
+		{/each}
+	</div>
+{/if}
